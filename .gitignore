# Uploaded files (keep the folders, ignore their contents)
/uploads/pdf/*
/uploads/tests/*
/uploads/solutions/*
!/uploads/**/.gitkeep
!/uploads/.htaccess

# Local environment / secrets
.env
config.local.php

# Local SQLite database + test scratch dirs
/data/
/_sqltest/

# One-off import staging (git tree + logs)
/_import/

# Local preview launch config (machine-specific paths)
/.claude/launch.json

# Editor / IDE
.vs/
.vscode/
*.code-workspace
.idea/

# OS noise
.DS_Store
Thumbs.db
*.log
